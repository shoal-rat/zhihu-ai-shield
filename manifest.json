{
  "manifest_version": 3,
  "name": "知乎 AI 清净器",
  "short_name": "知乎清净器",
  "version": "0.1.1",
  "description": "用本机小模型自动识别知乎低质量作者，把争吵、钓鱼、阴阳怪气挡在屏幕外。",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_title": "知乎 AI 清净器",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhihu.com/*",
        "https://zhuanlan.zhihu.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.zhihu.com/*",
    "https://zhuanlan.zhihu.com/*",
    "https://*.zhihu.com/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ]
}
